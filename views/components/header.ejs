<header>
    <!-- Navbar principale -->
    <nav class="navbar navbar-expand-lg navbar bg-light border-bottom border-1 shadow-sm">
        <div class="container-fluid mx-2">
            <!-- Logo and Brand Name -->
            <a class="navbar-brand d-flex align-items-center" href="/"> <!-- Link to index page -->
                <img src="/images/logo-black.png" alt="Logo" width="50" height="50"
                    class="d-inline-block align-middle me-2">
                <span class="navbar-brand brand-font align-middle">DanceEMotion</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <!-- Navbar links -->
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item nav-link-underline">
                        <a class="nav-link" href="/scuole">Scuole</a>
                    </li>
                    <li class="nav-item nav-link-underline">
                        <a class="nav-link" href="/corsi">Corsi</a>
                    </li>
                    <li class="nav-item nav-link-underline">
                        <a class="nav-link" href="/eventi">Eventi</a>
                    </li>
                    <!-- Login button for mobile view -->
                    <% if (!user) { %>
                        <li class="nav-item nav-link-underline d-flex d-lg-none">
                            <a class="nav-link" href="/accesso"><i class="bi bi-person"></i> Login</a>
                        </li>
                    <% } else { %>
                        <!-- User profile dropdown for mobile view -->
                        <li class="nav-item dropdown d-flex d-lg-none">
                            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="mobileUserDropdown"
                                role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <img src="/images/logo-black.png" alt="Foto Profilo" class="rounded-circle" width="30"
                                    height="30">
                                <span class="ms-2 align-middle">Profilo</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="mobileUserDropdown">
                                <li><a class="dropdown-item" href="/profilo"><i class="bi bi-person-circle"></i> Il mio profilo</a></li>
                                <li>
                                <form action="/logout" method="post" class="logout-btn dropdown-item p-0 m-0 border-0">
                                    <button type="submit" class="btn btn-link dropdown-item text-start">
                                    <i class="bi bi-box-arrow-right"></i> Logout
                                    </button>
                                </form>
                                </li>
                            </ul>
                        </li>
                    <% } %>
                </ul>
            </div>
            <% if (user) { %>
                <!-- User dropdown menu when logged in -->
                <div class="d-none d-lg-flex justify-content-end">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item nav-link-underline dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="userDropdown"
                                role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <img src="/images/logo-black.png" alt="Foto Profilo" class="rounded-circle" width="30"
                                    height="30">
                                <span class="ms-2 align-middle">Profilo</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                <li><a class="dropdown-item" href="/profilo"><i class="bi bi-person-circle"></i> Il mio profilo</a></li>
                                <li>
                                <form action="/logout" method="post" class="logout-btn dropdown-item p-0 m-0 border-0">
                                    <button type="submit" class="btn btn-link dropdown-item text-start">
                                    <i class="bi bi-box-arrow-right"></i> Logout
                                    </button>
                                </form>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            <% } else { %>
                <!-- If user is not logged in, show login button -->
                <div class="d-none d-lg-block">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item nav-link-underline">
                            <a class="nav-link" href="/accesso"><i class="bi bi-person"></i> Login</a>
                        </li>
                    </ul>
                </div>
            <% } %>
        </div>
    </nav>
</header>