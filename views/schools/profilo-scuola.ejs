<!DOCTYPE html>
<html lang="it">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>►DanceEMotion • Profilo Scuola◄</title>
    <!-- Favicon -->
    <link rel="icon" href="/images/logo-black.png" type="image/png" sizes="16x16">
    <link rel="icon" href="/images/logo-black.png" type="image/png" sizes="32x32">
    <link rel="icon" href="/images/logo-black.png" type="image/png" sizes="64x64">

    <!-- BS5 Bootstrap CSS and JS -->
    <link rel="stylesheet" href="/bs/css/bootstrap.min.css">
    <script src="/bs/js/bootstrap.bundle.min.js"></script>
    <!-- BS5 Icons CSS -->
    <link rel="stylesheet" href="/bs-icons/font/bootstrap-icons.min.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/stylesheets/base.css">
    <!-- Custom JS scripts -->
    <script src="/javascripts/calendar.js"></script>
    <script src="/javascripts/profilo-scuola.js" defer></script>
</head>

<body class="bg-white">
    <!-- Navbar principale -->
    <%- include('../components/header'); %>
    <!-- Fine Navbar principale -->

    <div class="container mt-4 mb-5">
        <div class="row">
            <!-- Sidebar -->
            <aside class="col-12 col-xl-3 mb-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <!-- Profilo scuola -->
                        <div class="d-flex align-items-center mb-3">
                            <img src="<%= (user.ImmagineProfilo) ? user.ImmagineProfilo : '/images/logo-black.png' %>" alt="Foto Profilo" class="rounded-circle me-3"
                                width="70" height="70">
                            <div>
                                <h4 class="mb-0"><%= user.Nome %></h4>
                            </div>
                        </div>
                        <hr>
                        <h5>Informazioni di contatto</h5>
                        <ul class="list-unstyled mb-0">
                            <li>
                                <i class="bi bi-geo-alt me-2"></i>
                                <strong>Indirizzo:</strong>
                                <%= user.Indirizzo + ', ' + user.Citta + ' (' + user.CAP + ')' + ' - ' + user.Regione %>
                            </li>
                            <li>
                                <i class="bi bi-telephone me-2"></i>
                                <strong>Telefono:</strong> <%= user.Telefono %>
                            </li>
                        </ul>
                        <div class="d-grid">
                            <button class="btn btn-outline-primary mt-3" type="button" data-bs-toggle="modal"
                                data-bs-target="#modalModificaScuola">
                                <i class="bi bi-pencil-square me-2"></i> Modifica Profilo
                            </button>
                            <!-- Modifica foto profilo scuola -->
                            <button class="btn btn-outline-secondary mt-2" type="button" data-bs-toggle="modal"
                                data-bs-target="#modalModificaFotoProfilo">
                                <i class="bi bi-image me-2"></i> Modifica Foto Profilo
                            </button>
                            <!-- Elimina profilo -->
                            <form action="/profilo/elimina-scuola" method="POST" class="mt-2">
                                <input type="hidden" name="IDScuola" value="<%= user.IDScuola %>">
                                <button type="submit" class="btn btn-outline-danger w-100">
                                    <i class="bi bi-trash me-2"></i> Elimina Profilo
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </aside>
            <!-- Fine Sidebar -->

            <!-- Contenuto principale -->
            <main class="col-12 col-xl-9">
                <!-- Management School Section -->
                <div class="card shadow mb-4">
                    <div class="card-body">
                        <h5 class="card-title d-flex align-items-center mb-3">
                            <i class="bi bi-gear-fill me-2"></i> Gestione Scuola
                        </h5>
                        <div class="row">
                            <!-- Modifica Descrizione Scuola -->
                            <div class="hover-effect-reverse col-12 col-md-4">
                                <div class="card shadow-sm h-100">
                                    <div class="card-body d-flex flex-column align-items-center justify-content-center">
                                        <i class="bi bi-info-circle display-4 text-warning mb-3"></i>
                                        <h5 class="card-title mb-2">Modifica Descrizione</h5>
                                        <p class="card-text text-center mb-3">Aggiorna la descrizione e le informazioni
                                            della tua scuola di ballo.</p>
                                        <button type="button" data-bs-toggle="modal" data-bs-target="#modalModificaDescrizione" class="btn btn-warning w-100">
                                            <i class="bi bi-pencil-square me-2"></i> Modifica Descrizione
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <!-- Aggiungi Corso -->
                            <div class="hover-effect-reverse col-12 col-md-4 mb-3 mb-md-0">
                                <div class="card shadow-sm h-100">
                                    <div class="card-body d-flex flex-column align-items-center justify-content-center">
                                        <i class="bi bi-plus-circle display-4 text-success mb-3"></i>
                                        <h5 class="card-title mb-2">Aggiungi Corso</h5>
                                        <p class="card-text text-center mb-3">Crea un nuovo corso per la tua scuola e
                                            gestisci le iscrizioni degli studenti.</p>
                                        <button type="button" class="btn btn-success w-100 mb-2" data-bs-toggle="modal"
                                            data-bs-target="#modalAggiungiCorso">
                                            <i class="bi bi-plus-circle me-2"></i> Aggiungi Corso
                                        </button>
                                        <button type="button" class="btn btn-outline-primary w-100 mb-2"
                                            data-bs-toggle="modal" data-bs-target="#modalSelezionaModificaCorso">
                                            <i class="bi bi-pencil me-2"></i> Modifica Corso
                                        </button>
                                        <button type="button" class="btn btn-outline-danger w-100"
                                            data-bs-toggle="modal" data-bs-target="#modalEliminaCorsoLista">
                                            <i class="bi bi-trash me-2"></i> Elimina Corso
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <!-- Aggiungi Evento -->
                            <div class="hover-effect-reverse col-12 col-md-4 mb-3 mb-md-0">
                                <div class="card shadow-sm h-100">
                                    <div class="card-body d-flex flex-column align-items-center justify-content-center">
                                        <i class="bi bi-calendar-plus display-4 text-primary mb-3"></i>
                                        <h5 class="card-title mb-2">Aggiungi Evento</h5>
                                        <p class="card-text text-center mb-3">Organizza un nuovo evento pubblico o
                                            privato per la tua scuola di danza.</p>
                                        <button type="button" class="btn btn-primary w-100 mb-2" data-bs-toggle="modal"
                                            data-bs-target="#modalAggiungiEvento">
                                            <i class="bi bi-calendar-plus me-2"></i> Aggiungi Evento
                                        </button>
                                        <button type="button" class="btn btn-outline-primary w-100 mb-2"
                                            data-bs-toggle="modal" data-bs-target="#modalModificaEvento">
                                            <i class="bi bi-pencil me-2"></i> Modifica Evento
                                        </button>
                                        <button type="button" class="btn btn-outline-danger w-100"
                                            data-bs-toggle="modal" data-bs-target="#modalEliminaEvento">
                                            <i class="bi bi-trash me-2"></i> Elimina Evento
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Fine Management School Section -->

                <!-- Gestione Iscritti ai Corsi -->
                <div class="card shadow mb-4">
                    <div class="card-body">
                        <h5 class="card-title d-flex align-items-center mb-3">
                            <i class="bi bi-people-fill me-2"></i> Gestione Iscritti ai Corsi
                        </h5>
                        <!-- Filtro per corso -->
                        <form class="mb-3">
                            <div class="row g-2 align-items-center">
                                <div class="col-auto">
                                    <label for="filtro-corso" class="col-form-label">Filtra per corso:</label>
                                </div>
                                <div class="col-auto">
                                    <select id="filtro-corso" class="form-select">
                                        <option value="tutti">Tutti i corsi</option>
                                        <% if (bookedCoursesDetails && bookedCoursesDetails.length > 0) { %>
                                            <% bookedCoursesDetails.filter((item, index, self) => self.findIndex(i => i.NomeCorso === item.NomeCorso) === index).forEach(course => { %>
                                                <option value="<%= course.NomeCorso %>">
                                                    <%= course.NomeCorso %>
                                                </option>
                                            <% }); %>
                                        <% } %>
                                    </select>
                                </div>
                                <div class="col-auto">
                                    Numero di iscritti: <span id="numero-iscritti">0</span>
                                </div>
                            </div>
                        </form>
                        <% if (bookedCoursesDetails && bookedCoursesDetails.length === 0) { %>
                            <div class="alert alert-info" role="alert">
                                Nessun iscritto ai corsi al momento.
                            </div>
                        <% } else {%>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle" id="tabella-iscritti">
                                <thead class="table-light">
                                    <tr>
                                        <th>Corso</th>
                                        <th>Ballerino/a</th>
                                        <th>Email</th>
                                        <th>Stato</th>
                                        <th>Azioni</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% bookedCoursesDetails.forEach(iscritto => { %>
                                    <tr data-corso="<%= iscritto.NomeCorso %>">
                                        <td><%= iscritto.NomeCorso %></td>
                                        <td><%= iscritto.NomeBallerino + ' ' + iscritto.CognomeBallerino %></td>
                                        <td><%= iscritto.EmailBallerino %></td>
                                        <td>
                                            <% if (iscritto.Stato === 'Accettata') { %>
                                                <span class="badge bg-success">Iscritto</span>
                                            <% } else if (iscritto.Stato === 'Richiesta') { %>
                                                <span class="badge bg-warning text-dark">In attesa</span>
                                            <% } else { %>
                                                <span class="badge bg-secondary"><%= iscritto.Stato %></span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (iscritto.Stato === 'Richiesta') { %>
                                                <form method="POST" action="/profilo/aggiorna-stato-iscrizione" id="form-mgmt-course-accept-<%= iscritto.IDIscrizione %>">
                                                    <input type="hidden" name="IDIscrizione" value="<%= iscritto.IDIscrizione %>">
                                                    <input type="hidden" name="Stato" value="Accettata">
                                                </form>
                                                <button type="submit" form="form-mgmt-course-accept-<%= iscritto.IDIscrizione %>" class="btn btn-outline-success btn-sm" title="Approva Iscrizione">
                                                    <i class="bi bi-check-circle"></i>
                                                </button>
                                                <form method="POST" action="/profilo/aggiorna-stato-iscrizione" id="form-mgmt-course-reject-<%= iscritto.IDIscrizione %>">
                                                    <input type="hidden" name="IDIscrizione" value="<%= iscritto.IDIscrizione %>">
                                                    <input type="hidden" name="Stato" value="Rifiutata">
                                                </form>
                                                <button type="submit" form="form-mgmt-course-reject-<%= iscritto.IDIscrizione %>" class="btn btn-outline-danger btn-sm" title="Rifiuta Iscrizione">
                                                    <i class="bi bi-x-circle"></i>
                                                </button>
                                            <% } else { %>
                                                <button class="btn btn-outline-secondary btn-sm" disabled
                                                    title="Iscrizione già gestita">
                                                    <i class="bi bi-check2-circle"></i>
                                                </button>
                                            <% } %>
                                        </td>
                                    </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                        <% } %>
                    </div>
                </div>

                <script>
                    
                </script>
                <!-- Fine Gestione Iscritti ai Corsi -->

                <!-- Gestione file allegati ai corsi -->
                <div class="card shadow mb-4">
                    <div class="card-body">
                        <h5 class="card-title d-flex align-items-center mb-3">
                            <i class="bi bi-file-earmark-text-fill me-2"></i> Gestione File Allegati ai Corsi
                        </h5>
                        <!-- Filtro per corso -->
                        <form class="mb-3">
                            <div class="row g-2 align-items-center">
                                <div class="col-auto">
                                    <label for="filtro-corso-file" class="col-form-label">Seleziona il corso:</label>
                                </div>
                                <div class="col-auto">
                                    <select id="filtro-corso-file" class="form-select">
                                        <option value="tutti">Tutti i corsi</option>
                                        <% if (courses && courses.length > 0) { %>
                                            <% courses.filter((item, index, self) => self.findIndex(i => i.Nome === item.Nome) === index).forEach(course => { %>
                                                <option value="<%= course.Nome %>" data-id-corso="<%= course.IDCorso %>">
                                                    <%= course.Nome %>
                                                </option>
                                            <% }); %>
                                        <% } %>
                                    </select>
                                </div>
                            </div>
                        </form>
                        <!-- Table -->
                        <% if (!attachments || attachments.length === 0) { %>
                            <div class="alert alert-info" role="alert">
                                Nessun file allegato ai corsi al momento.
                            </div>
                        <% } else { %>
                            <table class="table table-hover align-middle" id="tabella-allegati">
                                <thead>
                                    <tr>
                                        <th>Nome File</th>
                                        <th>Corso Associato</th>
                                        <th>Tipo File</th>
                                        <th>Azioni</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% console.log(attachments); attachments.forEach(attachment => { %>
                                        <tr>
                                            <td><%= attachment.NomeFile %></td>
                                            <td><%= attachment.NomeCorso %></td>
                                            <td><%= attachment.Tipologia.split('/')[0] %></td>
                                            <td>
                                                <a href="/profilo/download-allegato-scuola/<%= attachment.IDAllegato %>" class="btn btn-sm btn-primary">Scarica</a>
                                                <form action="/profilo/elimina-allegato/<%= attachment.IDAllegato %>" method="POST" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-danger">Elimina</button>
                                                </form>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        <% } %>
                        <!-- End Table -->
                        <form id="formCaricaFileCorso" action="/profilo/nuovo-allegato" method="POST" enctype="multipart/form-data">
                            <div class="mb-3">
                                <label for="fileCorso" class="form-label">Seleziona file da caricare</label>
                                <input type="hidden" name="IDCorso" id="id-corso-aggiungi-allegato">
                                <input type="file" class="form-control" id="fileCorso" name="Allegato" accept="video/mp4, video/webm, video/quicktime, video/ogg, audio/mpeg, audio/ogg, audio/wav" required>
                            </div>
                            <button type="submit" class="btn btn-primary">Carica File</button>
                        </form>
                    </div>
                </div>

                <!-- JS Caricamento file -->
                <script>
                    
                </script>

                <!-- Gestione Prenotazioni Eventi -->
                <div class="card shadow mb-4">
                    <div class="card-body">
                        <h5 class="card-title d-flex align-items-center mb-3">
                            <i class="bi bi-calendar-check-fill me-2"></i> Gestione Prenotazioni Eventi
                        </h5>
                        <!-- Filtro per evento -->
                        <form class="mb-3">
                            <div class="row g-2 align-items-center">
                                <div class="col-auto">
                                    <label for="filtro-evento" class="col-form-label">Filtra per evento:</label>
                                </div>
                                <div class="col-auto">
                                    <select id="filtro-evento" class="form-select">
                                        <option value="tutti">Tutti gli eventi</option>
                                        <% if(bookedEventsDetails && bookedEventsDetails.length > 0) { %>
                                            <% bookedEventsDetails.filter((item, index, self) => self.findIndex(i => i.NomeEvento === item.NomeEvento) === index).forEach(event => { %>
                                                <option value="<%= event.NomeEvento %>">
                                                    <%= event.NomeEvento %>
                                                </option>
                                            <% });} %>
                                    </select>
                                </div>
                                <div class="col-auto">
                                    Numero di prenotazioni: <span id="numero-prenotazioni">0</span>
                                </div>
                            </div>
                        </form>
                        <% if (bookedEventsDetails && bookedEventsDetails.length === 0) { %>
                            <div class="alert alert-info" role="alert">
                                Nessuna prenotazione per eventi al momento.
                            </div>
                        <% } else { %>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle" id="tabella-prenotazioni-eventi">
                                <thead class="table-light">
                                    <tr>
                                        <th>Evento</th>
                                        <th>Ballerino/a</th>
                                        <th>Email</th>
                                        <th>Stato</th>
                                        <th>Azioni</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% bookedEventsDetails.forEach(prenotazione => { %>
                                        <tr data-evento="<%= prenotazione.NomeEvento %>">
                                            <td><%= prenotazione.NomeEvento %></td>
                                            <td><%= prenotazione.NomeBallerino + ' ' + prenotazione.CognomeBallerino %></td>
                                            <td><%= prenotazione.EmailBallerino %></td>
                                            <td>
                                                <% if (prenotazione.Stato === 'Richiesta') { %>
                                                    <span class="badge bg-warning text-dark">In attesa</span>
                                                <% } else if (prenotazione.Stato === 'Accettata') { %>
                                                    <span class="badge bg-success">Confermato</span>
                                                <% } else { %>
                                                    <span class="badge bg-secondary"><%= prenotazione.Stato %></span>
                                                <% } %>
                                            <td>
                                                <% if (prenotazione.Stato === 'Richiesta') { %>
                                                    <form method="POST" action="/profilo/aggiorna-stato-prenotazione" id="form-mgmt-event-accept-<%= prenotazione.IDPrenotazione %>">
                                                        <input type="hidden" name="IDPrenotazione" value="<%= prenotazione.IDPrenotazione %>">
                                                        <input type="hidden" name="Stato" value="Accettata">
                                                    </form>
                                                    <button type="submit" form="form-mgmt-event-accept-<%= prenotazione.IDPrenotazione %>" class="btn btn-outline-success btn-sm" title="Conferma Prenotazione">
                                                        <i class="bi bi-check-circle"></i>
                                                    </button>
                                                    <form method="POST" action="/profilo/aggiorna-stato-prenotazione" id="form-mgmt-event-reject-<%= prenotazione.IDPrenotazione %>">
                                                        <input type="hidden" name="IDPrenotazione" value="<%= prenotazione.IDPrenotazione %>">
                                                        <input type="hidden" name="Stato" value="Rifiutata">
                                                    </form>
                                                    <button type="submit" form="form-mgmt-event-reject-<%= prenotazione.IDPrenotazione %>" class="btn btn-outline-danger btn-sm" title="Rifiuta Prenotazione">
                                                        <i class="bi bi-x-circle"></i>
                                                    </button>
                                                <% } else { %>
                                                    <button class="btn btn-outline-secondary btn-sm" disabled
                                                        title="Prenotazione già gestita">
                                                        <i class="bi bi-check2-circle"></i>
                                                    </button>
                                                <% } %>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                        <% } %>
                    </div>
                </div>
                <script>
                    
                </script>
                <!-- Fine Gestione Prenotazioni Eventi -->

                <!-- Calendar area -->
                <div class="card shadow-sm mt-4">
                    <div class="card-body">
                        <h5 class="card-title d-flex align-items-center">
                            <i class="bi bi-calendar-fill me-2"></i>Calendario Corsi
                        </h5>
                    </div>
                    <!-- Current Month and Buttons (gathered together) -->
                    <div class="d-flex justify-content-between align-items-center p-2">
                        <button class="btn btn-outline-secondary" id="prev-month"><i
                                class="bi bi-chevron-left"></i></button>
                        <h6 id="current-month" class="text-center mb-0"></h6>
                        <button class="btn btn-outline-secondary" id="next-month"><i
                                class="bi bi-chevron-right"></i></button>
                    </div>
                    <div id="calendar" class="table-responsive p-2">
                        <table class="table table-bordered text-center">
                            <thead>
                                <tr>
                                    <th>Lunedì</th>
                                    <th>Martedì</th>
                                    <th>Mercoledì</th>
                                    <th>Giovedì</th>
                                    <th>Venerdì</th>
                                    <th>Sabato</th>
                                    <th>Domenica</th>
                                </tr>
                            </thead>
                            <tbody id="calendar-body">
                                <!-- Calendar days will be dynamically generated here -->
                            </tbody>
                        </table>
                    </div>
                </div>
                <!-- Fine Calendar area-->
                <!-- Reviews Answer Section -->
                <div class="card shadow-sm mt-4">
                    <div class="card-body">
                        <h5 class="card-title d-flex align-items-center">
                            <i class="bi bi-chat-left-text-fill me-2"></i>Risposte Recensioni
                        </h5>
                        <p class="card-text">Gestisci le recensioni e le domande degli utenti.</p>
                        <% if (!coursesFeedback || coursesFeedback.length === 0) { %>
                            <div class="alert alert-info" role="alert">
                                Nessuna recensione al momento.
                            </div>
                        <% } else { %>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Recensione</th>
                                        <th>Email</th>
                                        <th>Corso</th>
                                        <th>Azioni</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% coursesFeedback.forEach(feedback => { %>
                                    <tr>
                                        <td><%= (feedback.Corpo.length > 42) ? feedback.Corpo.substring(0, 42) + '...' : feedback.Corpo %></td>
                                        <td><%= feedback.EmailBallerino %></td>
                                        <td><%= feedback.NomeCorso %></td>
                                        <% if (feedback.IDRisposta) { %>
                                            <td>
                                                <span class="badge bg-success">Risposta inviata</span>
                                            </td>
                                        <% } else { %>
                                        <td><button class="btn btn-outline-primary btn-sm answer-feedback" data-feedback-id="<%= feedback.IDRecensione %>" data-feedback-body="<%= feedback.Corpo %>" data-feedback-stars="<%= feedback.Valutazione %>">Rispondi</button></td>
                                        <% } %>
                                    </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                        <% } %>
                    </div>
                </div>
                <!-- Fine Reviews Answer Section -->
            </main>
            <!-- Fine Contenuto principale -->
        </div>
    </div>

    <!-- Footer -->
    <%- include('../components/footer'); %>
    <!-- Fine Footer -->


    <% if (success) { %>
    <!-- Toast for successful flash messages -->
    <% success.forEach(function(message) { %>
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999">
        <div class="toast show" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <strong class="me-auto">Successo</strong>
                <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body">
                <%= message %>
            </div>
        </div>
    </div>
    <% });} %>

    <% if (error) { %>
        <% error.forEach(function(message) { %>
            <!-- Toast for error flash messages -->
            <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999">
                <div class="toast show" role="alert" aria-live="assertive" aria-atomic="true">
                    <div class="toast-header">
                        <strong class="me-auto text-danger">Errore</strong>
                        <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
                    </div>
                    <div class="toast-body">
                        <%= message %>
                    </div>
                </div>
            </div>
    <% });} %>

    <!-- Modal Modifica Descrizione -->
