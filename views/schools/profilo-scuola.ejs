        aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header bg-primary text-white rounded-top-4">
                    <h5 class="modal-title d-flex align-items-center" id="modalRispondiFeedbackLabel">
                        <i class="bi bi-chat-dots me-2 fs-3"></i>
                        Rispondi al Feedback
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                        aria-label="Chiudi"></button>
                </div>
                <div class="modal-body bg-light px-4 py-4">
                    <form id="rispondiFeedbackForm" action="/profilo/rispondi-feedback" method="POST">
                        <input type="hidden" class="form-control" id="feedbackId" name="IDRecensione"
                            placeholder="ID del feedback a cui rispondere" required>
                        <!-- Show feedback content -->
                        <div class="mb-3">
                            <label for="feedbackStars" class="form-label">Valutazione</label>
                            <input type="text" class="form-control" id="feedbackStars"
                                placeholder="Valutazione del feedback" readonly>
                        </div>
                        <div class="mb-3">
                            <label for="feedbackContent" class="form-label">Contenuto del Feedback</label>
                            <textarea class="form-control" id="feedbackContent"
                                rows="4" readonly></textarea>
                        </div>
                        <div class="mb-3">
                            <label for="rispostaFeedback" class="form-label">Risposta</label>
                            <textarea class="form-control" id="rispostaFeedback" name="Corpo"
                                rows="4" placeholder="Scrivi la tua risposta al feedback" required></textarea>
                        </div>
                    </form>
                </div>
                <div class="modal-footer bg-white rounded-bottom-4 d-flex justify-content-between px-4 py-3">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-2"></i>Annulla
                    </button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4" form="rispondiFeedbackForm">
                        <i class="bi bi-send me-2"></i>Invia Risposta
                    </button>
                </div>
            </div>
        </div>
    </div>
    <!-- Fine Modal Rispondi Feedback -->

