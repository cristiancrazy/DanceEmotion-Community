                                        data-course-name="<%= course.Nome %>"
                                        data-course-instructor="<%= course.Istruttore %>"
                                        data-course-type="<%= course.Tipologia %>" 
                                        data-course-category="<%= course.CategoriaCorso %>"
                                        data-course-level="<%= course.Livello %>"
                                        data-course-price="<%= course.Prezzo %>"
                                        data-course-start-date="<%= (course.DataInizio) ? new Date(course.DataInizio).toISOString().split('T')[0] : '' %>"
